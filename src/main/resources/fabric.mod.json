{
  "schemaVersion": 1,
  "id": "minimap-ce",
  "version": "3.2.0",
  "name": "Minimap CE",
  "description": "JourneyMap-inspired minimap with texture-sampled colors, waypoint management, entity tracking, and in-world beacons for Better Than Wolves CE 3.0.0",
  "authors": [
    "chronicboy31"
  ],
  "license": "CC0-1.0",
  "icon": "assets/minimap-ce/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.fabricmc.example.BTWNavigatorMod"
    ],
    "btw:addon": [
      "btw.community.example.BTWNavigatorAddon"
    ]
  },
  "custom": {
    "btw:addon_prefix": "NAV"
  },
  "accessWidener": "minimap-ce.accesswidener",
  "mixins": [
    "minimap-ce.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.14.19",
    "minecraft": "1.6.4"
  }
}